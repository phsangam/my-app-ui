# Local dev only: UI (port 3000) talks directly to each API's own port.
# In production these are unset, so the app falls back to relative /api/* paths,
# which the Ingress/ALB routes to the correct microservice (same-origin, no CORS needed).
REACT_APP_ORDERS_URL=http://localhost:5001
REACT_APP_PAYMENTS_URL=http://localhost:5002
REACT_APP_USERS_URL=http://localhost:5003
